{
  "name": "classguard-server",
  "version": "1.0.0",
  "description": "ClassGuard monitoring and control central server with Electron dashboard",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "server": "node server.js",
    "dist": "electron-builder --win --x64"
  },
  "dependencies": {
    "express": "^4.19.2",
    "socket.io": "^4.7.5"
  },
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.classguard.minito",
    "productName": "Minito_professor",
    "win": {
      "target": "nsis",
      "artifactName": "${productName}_setup.${ext}"
    },
    "directories": {
      "output": "dist"
    }
  },
  "author": "Antigravity",
  "license": "ISC"
}
